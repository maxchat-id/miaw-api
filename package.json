{
  "name": "miaw-api",
  "version": "1.1.0",
  "description": "REST API wrapper for miaw-core - Multiple Instance of App WhatsApp",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "dev:start": "node --env-file-if-exists=.env -r ts-node/register src/server.ts",
    "test": "vitest run",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run -c vitest.config.ts --coverage",
    "test:coverage:all": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "whatsapp",
    "api",
    "rest",
    "miaw-core",
    "whatsapp-bot",
    "multi-instance"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@scalar/fastify-api-reference": "^1.40.9",
    "@whiskeysockets/baileys": "^6.7.21",
    "fastify": "^5.2.0",
    "miaw-core": "^1.9.2",
    "pino": "^8.19.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.11.19",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
