# Server Configuration
PORT=3000
HOST=0.0.0.0

# API Key (single key for all requests)
API_KEY=your-secret-api-key-here

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-here
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=1000
# Hosts exempt from the webhook SSRF check (comma-separated; `host` = any port,
# `host:port` = that port only). Use for co-located consumers, e.g. localhost:4000
# WEBHOOK_SSRF_ALLOWLIST=localhost:4000

# CORS
CORS_ORIGIN=*

# Session Storage
SESSION_PATH=./sessions

# Logging
LOG_LEVEL=info
